# Local Python demo can use the SQLite default from config.py without setting ABACUS_DB_URL.
# Copy this file to .env when you want to run the Docker/PostgreSQL path.

POSTGRES_DB=abacus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

ABACUS_DB_URL=postgresql+psycopg://postgres:postgres@postgres:5432/abacus
ABACUS_NODE_NAME_API_1=api-1
ABACUS_NODE_NAME_API_2=api-2
